# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Site URL (used for sitemap, OG, and canonical URLs)
# On Vercel: VERCEL_PROJECT_PRODUCTION_URL is set automatically (takes priority)
# For local dev: set SITE_URL
SITE_URL=http://localhost:3000

# Sanity Webhook Secret
# 1. Go to sanity.io/manage > your project > API > Webhooks
# 2. Create a webhook pointing to https://your-domain.com/api/revalidate
# 3. Set a secret and copy it here
SANITY_WEBHOOK_SECRET=

# Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Efferd Registry (optional, for internal component registry)
EFFERD_REGISTRY_TOKEN=
